{
  "extends": "claude-code",
  "meta": {
    "name": "dev"
  },
  "filesystem": {
    "allow": [
      ".",
      "$HOME/.cache",
      "$HOME/go",
      "$HOME/.bazel",
      "$HOME/.rustup",
      "$HOME/.cargo",
      "$HOME/.local/state/nix",
      "$HOME/.local/state/mise",
      "$HOME/.local/share/mise",
      "$HOME/.local/share/direnv",
      "$HOME/Library/Caches",
      "/nixpkgs",
      "/nix",
      "/var/tmp",
      "/private/var"
    ],
    "read": [
      "$HOME/.nix-profile",
      "$HOME/.config"
    ],
    "read_file": [
      "$HOME/.bashrc",
      "$HOME/.bazelrc"
    ],
    "bypass_protection": [
      "$HOME/.bashrc"
    ]
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow iokit-open (iokit-user-client-class \"RootDomainUserClient\"))"
  ]
}
