{
  "name": "dev",
  "image": "ghcr.io/rahulmutt/dev:sha-3274482",
  "workspaceFolder": "/workspace",
  "remoteUser": "root",
  "mounts": [
    "source=devpod-home-cache,target=/root/.cache,type=volume",
    "source=devpod-home-local,target=/root/.local,type=volume",
  ],
  "postCreateCommand": "post-create.sh",
  "customizations": {
    "devpod": {
      "ide": "none"
    }
  }
}
